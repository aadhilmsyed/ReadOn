# Visualization microservice — copy to `.env` and merge with repo root `.env` (provides VISUALIZATION_DATABASE_URL, OPENAI_API_KEY).
# Convention: `REPLACE_ME` = set in real `.env` (redact here). `NULL` = placeholder not yet replaced in real `.env`.

############################
# Visualization — storage & DB TLS (Postgres URL: VISUALIZATION_DATABASE_URL in repo root `.env`)
############################
VISUALIZATION_STORAGE_DRIVER=REPLACE_ME
VISUALIZATION_DB_SSL=REPLACE_ME

############################
# Visualization — OpenAI images (API key: OPENAI_API_KEY in repo root `.env`)
############################
VISUALIZATION_AI_IMAGE_API_ENDPOINT=REPLACE_ME
VISUALIZATION_AI_TIMEOUT_MS=REPLACE_ME

############################
# Visualization — HTTP API limits
############################
VISUALIZATION_CACHE_TTL=REPLACE_ME
VISUALIZATION_RATE_LIMIT_MAX=REPLACE_ME
VISUALIZATION_RATE_LIMIT_WINDOW_MS=REPLACE_ME

############################
# Visualization — HTTP server
############################
VISUALIZATION_PORT=REPLACE_ME
VISUALIZATION_JSON_BODY_LIMIT=REPLACE_ME
