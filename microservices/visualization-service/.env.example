# Visualization microservice — copy to `.env` and merge with repo root `.env`.
# Convention: `REPLACE_ME` = populated in real `.env` (redact). `NULL` = placeholder in real `.env`.

############################
# Database Configuration (PostgreSQL on Cloud SQL)
############################
STORAGE_DRIVER=REPLACE_ME
DB_HOST=REPLACE_ME
DB_PORT=REPLACE_ME
DB_NAME=REPLACE_ME
DB_USER=REPLACE_ME
DB_PASSWORD=REPLACE_ME
DB_SSL=REPLACE_ME

############################
# AI Provider (OpenAI DALL-E 3) — visualization only
############################
AI_IMAGE_API_KEY=REPLACE_ME
AI_IMAGE_API_ENDPOINT=REPLACE_ME
AI_TIMEOUT=REPLACE_ME

############################
# Cache Configuration
############################
CACHE_TTL=REPLACE_ME

############################
# Rate Limiting
############################
RATE_LIMIT_MAX=REPLACE_ME
RATE_LIMIT_WINDOW=REPLACE_ME

############################
# Server Configuration
############################
PORT=REPLACE_ME
JSON_BODY_LIMIT=REPLACE_ME
