# Audiobook / TTS (William) ‚Äî copy to `.env`.
# Convention: `REPLACE_ME` = populated in real `.env` (redact). `NULL` = placeholder in real `.env`.
#
# Local dev: port 3004 (see root READON_AUDIOBOOK_SERVICE_URL).

PORT=3004
HOST=0.0.0.0
SERVICE_NAME=audiobook-service
