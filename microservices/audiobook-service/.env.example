# Audiobook / TTS — copy to `.env` and merge with repo root `.env` if you also need ReadOn shared vars.
# Google TTS uses a separate GCP project from ReadOn core; credentials stay in this service only.
# Convention: `REPLACE_ME` = set in real `.env` (redact here). `NULL` = placeholder not yet replaced in real `.env`.

GOOGLE_APPLICATION_CREDENTIALS=REPLACE_ME

GOOGLE_SERVICE_ACCOUNT_TYPE=REPLACE_ME
GOOGLE_SERVICE_ACCOUNT_PROJECT_ID=REPLACE_ME
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY_ID=REPLACE_ME
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=REPLACE_ME
GOOGLE_SERVICE_ACCOUNT_CLIENT_EMAIL=REPLACE_ME
GOOGLE_SERVICE_ACCOUNT_CLIENT_ID=REPLACE_ME
GOOGLE_SERVICE_ACCOUNT_AUTH_URI=REPLACE_ME
GOOGLE_SERVICE_ACCOUNT_TOKEN_URI=REPLACE_ME
GOOGLE_SERVICE_ACCOUNT_AUTH_PROVIDER_X509_CERT_URL=REPLACE_ME
GOOGLE_SERVICE_ACCOUNT_CLIENT_X509_CERT_URL=REPLACE_ME
GOOGLE_SERVICE_ACCOUNT_UNIVERSE_DOMAIN=REPLACE_ME

GCP_PROJECT_ID=REPLACE_ME
