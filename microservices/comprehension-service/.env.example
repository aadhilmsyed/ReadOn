# Comprehension microservice (Kuhoo) — copy to `.env` and merge with repo root `.env`.
#
# Persistence (see db/client.js):
# - If DATABASE_URL is set → used first (typical local dev: Postgres TCP URL).
# - Else READON_DATABASE_NAME + CLOUDSQL_CONNECTION_NAME → Unix socket /cloudsql/... (Cloud Run with volume mount).
# For local TCP: set DATABASE_URL and omit or comment READON_DATABASE_NAME to avoid accidental socket host.
# Convention: `REPLACE_ME` = populated in real `.env` (redact). `NULL` = placeholder in real `.env`.

DATABASE_URL=REPLACE_ME
CLOUDSQL_CONNECTION_NAME=REPLACE_ME

READON_DEPLOY_ENV=REPLACE_ME
REGION=REPLACE_ME

READON_STORAGE_BUCKET=REPLACE_ME
# Optional when DATABASE_URL is unset (Cloud Run socket mode):
READON_DATABASE_NAME=REPLACE_ME

SERVICE_NAME=REPLACE_ME
SERVICE_VERSION=REPLACE_ME

PORT=3002
HOST=0.0.0.0

READON_LOG_LEVEL=REPLACE_ME
READON_READY_REQUIRE_CLOUDSQL_MOUNT=REPLACE_ME

READON_AUDIOBOOK_SERVICE_URL=NULL
READON_PHONICS_SERVICE_URL=NULL
READON_COMPREHENSION_SERVICE_URL=NULL
READON_VISUALIZATION_SERVICE_URL=NULL

READON_COMPREHENSION_LLM_PROVIDER=vertex
VERTEX_AI_PROJECT=REPLACE_ME
VERTEX_AI_LOCATION=us-central1
READON_COMPREHENSION_VERTEX_MODEL=gemini-2.5-flash
READON_COMPREHENSION_LLM_TIMEOUT_MS=REPLACE_ME
READON_COMPREHENSION_CIRCUIT_BREAKER_FAILURE_THRESHOLD=REPLACE_ME
READON_COMPREHENSION_CIRCUIT_BREAKER_RESET_MS=REPLACE_ME

READON_REDIS_HOST=NULL
READON_REDIS_PORT=REPLACE_ME
READON_REDIS_URL=NULL

# OpenAI fallback (only when READON_COMPREHENSION_LLM_PROVIDER=openai)
OPENAI_API_KEY=REPLACE_ME
