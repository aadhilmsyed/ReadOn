# Comprehension microservice — copy to `.env` and merge with repo root `.env` (provides COMPREHENSION_DATABASE_URL, OPENAI_API_KEY).
# Convention: `REPLACE_ME` = set in real `.env` (redact here). `NULL` = placeholder not yet replaced in real `.env`.

############################
# Comprehension — logical database (matches DB name in COMPREHENSION_DATABASE_URL)
############################
COMPREHENSION_DATABASE_NAME=REPLACE_ME

############################
# Comprehension — LLM / resilience
############################
READON_COMPREHENSION_LLM_PROVIDER=NULL
READON_COMPREHENSION_LLM_TIMEOUT_MS=REPLACE_ME
READON_COMPREHENSION_CIRCUIT_BREAKER_FAILURE_THRESHOLD=REPLACE_ME
READON_COMPREHENSION_CIRCUIT_BREAKER_RESET_MS=REPLACE_ME
