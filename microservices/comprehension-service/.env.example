# Comprehension microservice — copy to `.env` and merge with repo root `.env`.
# Convention: `REPLACE_ME` = populated in real `.env` (redact). `NULL` = placeholder in real `.env`.

############################
# Postgres (`comprehension` database)
############################
COMPREHENSION_DATABASE_URL=REPLACE_ME

############################
# OpenAI (comprehension LLM) — separate from visualization AI_IMAGE_API_KEY
############################
OPENAI_API_KEY=REPLACE_ME

############################
# Comprehension — LLM / resilience
############################
READON_COMPREHENSION_LLM_PROVIDER=NULL
READON_COMPREHENSION_LLM_TIMEOUT_MS=REPLACE_ME
READON_COMPREHENSION_CIRCUIT_BREAKER_FAILURE_THRESHOLD=REPLACE_ME
READON_COMPREHENSION_CIRCUIT_BREAKER_RESET_MS=REPLACE_ME
