# Dashboard microservice — copy to `.env` and merge with repo root `.env` (provides DASHBOARD_DATABASE_URL, READON_CLOUDSQL_TCP_*).
# DASHBOARD_DATABASE_URL points at the `dashboard` logical database on the shared instance.
# Convention: `REPLACE_ME` = set in real `.env` (redact here). `NULL` = placeholder not yet replaced in real `.env`.

############################
# Dashboard — process
############################
DASHBOARD_SERVICE_NAME=REPLACE_ME
DASHBOARD_SERVICE_VERSION=REPLACE_ME
DASHBOARD_PORT=REPLACE_ME
DASHBOARD_HOST=REPLACE_ME
DASHBOARD_NODE_ENV=REPLACE_ME
DASHBOARD_CORS_ORIGIN=REPLACE_ME

############################
# Dashboard — Postgres pools (shared host; logical DB names per feature)
############################
DASHBOARD_PGHOST=REPLACE_ME
DASHBOARD_PGPORT=REPLACE_ME
DASHBOARD_PGUSER=REPLACE_ME
DASHBOARD_PGPASSWORD=REPLACE_ME

DASHBOARD_DB_PHONICS=REPLACE_ME
DASHBOARD_DB_COMPREHENSION=REPLACE_ME
DASHBOARD_DB_VISUALIZATION=REPLACE_ME
DASHBOARD_DB_AUDIOBOOK=REPLACE_ME
DASHBOARD_DB_DASHBOARD=REPLACE_ME
