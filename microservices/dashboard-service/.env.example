# dashboard-service local env (template). Copy to .env (gitignored).
SERVICE_NAME=dashboard-service
SERVICE_VERSION=local-dev
PORT=4100
HOST=0.0.0.0
NODE_ENV=development

# Shared Cloud SQL (readon-sql) — public IP for local dev.
PGHOST=35.226.133.224
PGPORT=5432
PGUSER=postgres
# Quote the password if it contains special chars (", , space, etc.)
PGPASSWORD='REPLACE_ME'

# Feature → database name mapping. visualization currently maps to `images`
# (legacy DB name; configured here so service code stays consistent).
PHONICS_DB=phonics
COMPREHENSION_DB=comprehension
VISUALIZATION_DB=images
AUDIOBOOK_DB=audiobook

# Cross-feature DB (credits and other user-scoped dashboard data).
DASHBOARD_DB=dashboard

# CORS — Next.js dev server on 3000 is the only client locally.
CORS_ORIGIN=http://localhost:3000
