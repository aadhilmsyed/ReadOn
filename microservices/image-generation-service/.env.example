# Image generation microservice (Anand) — copy to `.env`.
# Convention: `REPLACE_ME` = populated in real `.env` (redact). `NULL` = placeholder in real `.env`.

# Database Configuration (PostgreSQL on Cloud SQL)
STORAGE_DRIVER=REPLACE_ME
DB_HOST=REPLACE_ME
DB_PORT=REPLACE_ME
DB_NAME=REPLACE_ME
DB_USER=REPLACE_ME
DB_PASSWORD=REPLACE_ME
DB_SSL=REPLACE_ME

# AI Provider — Vertex AI Gemini (default) or OpenAI (fallback)
AI_IMAGE_PROVIDER=vertex
VERTEX_AI_PROJECT=REPLACE_ME
VERTEX_AI_LOCATION=us-central1
AI_IMAGE_MODEL=gemini-2.5-flash-image
AI_TIMEOUT=120000

# OpenAI fallback (only when AI_IMAGE_PROVIDER=openai)
AI_IMAGE_API_KEY=REPLACE_ME
AI_IMAGE_API_ENDPOINT=https://api.openai.com/v1/images/generations

# Cache Configuration
CACHE_TTL=REPLACE_ME

# Rate Limiting
RATE_LIMIT_MAX=REPLACE_ME
RATE_LIMIT_WINDOW=REPLACE_ME

# Server Configuration
PORT=3001
JSON_BODY_LIMIT=1mb

# Google Cloud Storage Configuration
GCP_PROJECT_ID=REPLACE_ME
GOOGLE_APPLICATION_CREDENTIALS=REPLACE_ME
READON_STORAGE_BUCKET=REPLACE_ME
