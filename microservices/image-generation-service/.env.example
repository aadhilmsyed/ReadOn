# Database Configuration
STORAGE_DRIVER=postgres
DB_HOST=YOUR_CLOUD_SQL_PUBLIC_IP
DB_PORT=5432
DB_NAME=image_generation
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_SSL=true

# AI Provider Configuration
AI_IMAGE_API_KEY=your_openai_api_key_here
AI_IMAGE_API_ENDPOINT=https://api.openai.com/v1/images/generations
AI_TIMEOUT=30000

# Cache Configuration
CACHE_TTL=3600

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000

# Server Configuration
PORT=3001
JSON_BODY_LIMIT=1mb
