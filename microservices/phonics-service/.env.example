# Phonics microservice — copy to `.env` and merge with repo root `.env` (provides PHONICS_DATABASE_URL).
# Convention: `REPLACE_ME` = set in real `.env` (redact here). `NULL` = placeholder not yet replaced in real `.env`.

############################
# Phonics — Merriam-Webster
############################
MERRIAM_WEBSTER_API_KEY=REPLACE_ME
MERRIAM_WEBSTER_API_KEY_COLLEGIATE=REPLACE_ME

############################
# Phonics — Postgres TLS (connection string: PHONICS_DATABASE_URL in repo root `.env`)
############################
PHONICS_DB_SSL=REPLACE_ME
# Optional local override of root PHONICS_DATABASE_URL (e.g. Cloud SQL Auth Proxy on localhost):
# PHONICS_DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/phonics
