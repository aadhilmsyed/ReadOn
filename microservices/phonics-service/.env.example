# Phonics microservice — copy to `.env` and merge with repo root `.env` (PHONICS_DATABASE_URL).
# Convention: `REPLACE_ME` = populated in real `.env` (redact). `NULL` = placeholder in real `.env`.
#
# Local dev: listen on port 3001 (see root READON_PHONICS_SERVICE_URL).

PORT=3001
HOST=0.0.0.0
SERVICE_NAME=phonics-service
SERVICE_VERSION=local-dev

MERRIAM_WEBSTER_API_KEY=REPLACE_ME
MERRIAM_WEBSTER_API_KEY_COLLEGIATE=REPLACE_ME

PHONICS_DB_SSL=REPLACE_ME
PHONICS_DATABASE_URL=REPLACE_ME
