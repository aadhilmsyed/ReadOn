# ReadOn - environment configuration template
#
# Notes:
# - Do NOT commit real secrets. Use `gcloud secrets` / Secret Manager when you're ready.
# - Cloud Run injects most runtime env vars from `gcloud run deploy` / `ops/gcp/deploy-*.sh`.
# - Same GCP project hosts **prod** and **test** stacks with different names (see docs/environment-separation.md).
# - Dashboard PG pools are configured here (Next.js). OpenAI keys for visualization/comprehension live in those microservices (see their `.env.example`).
# - Microservices keep only service-specific keys in microservices/<name>/.env.example; merge with this file when running locally.
# - `.env.example` convention: `REPLACE_ME` = real `.env` has a value (redact here). `NULL` = real `.env` still uses a placeholder (not implemented).

############################
# Which stack (local reference)
############################
# prod: readon-main, readon-phonics, … and bucket readon-<project>-assets, DB readon
# test: readon-main-test, … and bucket readon-<project>-assets-test, DB readon_test
# (Deploy scripts export READON_DEPLOY_ENV from ops/gcp/vars.sh so nested bash steps stay aligned.)
READON_DEPLOY_ENV=REPLACE_ME

############################
# Shared (all environments)
############################
#GCP_PROJECT_ID=readon-492106
REGION=REPLACE_ME

# Artifact Registry (single repo for both environments; image tags include service name + version)
#ARTIFACT_REGISTRY_REPO=readon-artifacts
#ARTIFACT_REGISTRY_LOCATION=us-central1

# Cloud SQL instance (shared). Logical databases are split: prod uses `readon`, test uses `readon_test`.
#READON_SQL_INSTANCE=readon-sql
CLOUDSQL_CONNECTION_NAME=REPLACE_ME

############################
# Shared Cloud SQL — TCP (public IP / authorized networks; proxy uses 127.0.0.1)
############################
READON_CLOUDSQL_TCP_HOST=REPLACE_ME
READON_CLOUDSQL_TCP_PORT=REPLACE_ME
READON_CLOUDSQL_TCP_USER=REPLACE_ME
READON_CLOUDSQL_TCP_PASSWORD=REPLACE_ME

############################
# Per-service Postgres connection URLs (shared instance; different logical databases)
############################
# Never use a bare DATABASE_URL — each service has its own. Merge repo root `.env` when running microservices locally.
PHONICS_DATABASE_URL=REPLACE_ME
VISUALIZATION_DATABASE_URL=REPLACE_ME
COMPREHENSION_DATABASE_URL=REPLACE_ME
DASHBOARD_DATABASE_URL=REPLACE_ME

############################
# Production-specific (READON_DEPLOY_ENV=prod)
############################
# Cloud Run service names
#READON_MAIN_SERVICE_NAME=readon-main
#READON_PHONICS_SERVICE_NAME=readon-phonics
#READON_COMPREHENSION_SERVICE_NAME=readon-comprehension
#READON_VISUALIZATION_SERVICE_NAME=readon-visualization
#READON_AUDIOBOOK_SERVICE_NAME=readon-audiobook

# Object storage (prod assets)
READON_STORAGE_BUCKET=REPLACE_ME

# Postgres database name on the shared instance (prod target — main / Next app)
READON_DATABASE_NAME=REPLACE_ME

# Runtime service accounts (emails); created by ops/gcp/provision.sh
#READON_MAIN_SA_EMAIL=readon-main-sa@readon-492106.iam.gserviceaccount.com
# … phonics / comprehension / visualization / audiobook similarly without -test suffix

############################
# Test-specific (READON_DEPLOY_ENV=test)
############################
# Service names
#READON_MAIN_SERVICE_NAME=readon-main-test
#READON_PHONICS_SERVICE_NAME=readon-phonics-test
# … etc.

#READON_STORAGE_BUCKET=readon-492106-assets-test
#READON_DATABASE_NAME=readon_test
#READON_MAIN_SA_EMAIL=readon-main-sa-test@readon-492106.iam.gserviceaccount.com

############################
# Common service identity (typical local / main app)
############################
SERVICE_NAME=REPLACE_ME
#SERVICE_VERSION=local-dev
SERVICE_VERSION=REPLACE_ME

############################
# Cloud Run runtime
############################
PORT=REPLACE_ME
HOST=REPLACE_ME

############################
# Logging / observability
############################
READON_LOG_LEVEL=REPLACE_ME

############################
# Cloud SQL socket / readiness (skeleton)
############################
# If true, `/ready` returns 503 until /cloudsql/<connectionName> exists.
READON_READY_REQUIRE_CLOUDSQL_MOUNT=REPLACE_ME

############################
# Next.js orchestrator (dashboard / features)
############################
# Base URL for dashboard-service (required when orchestrators call dashboard).
READON_DASHBOARD_SERVICE_URL=REPLACE_ME
READON_FEATURE_CREDIT_COST=REPLACE_ME

############################
# Dashboard — embedded in Next.js (Tyler)
############################
DASHBOARD_SERVICE_NAME=REPLACE_ME
DASHBOARD_SERVICE_VERSION=REPLACE_ME
DASHBOARD_PORT=REPLACE_ME
DASHBOARD_HOST=REPLACE_ME
DASHBOARD_NODE_ENV=REPLACE_ME
DASHBOARD_CORS_ORIGIN=REPLACE_ME
PGHOST=REPLACE_ME
PGPORT=REPLACE_ME
PGUSER=REPLACE_ME
PGPASSWORD=REPLACE_ME
PHONICS_DB=REPLACE_ME
COMPREHENSION_DB=REPLACE_ME
VISUALIZATION_DB=REPLACE_ME
AUDIOBOOK_DB=REPLACE_ME
DASHBOARD_DB=REPLACE_ME

############################
# Service-to-service (placeholders; deploy-stack.sh sets URLs in Cloud Run)
############################
READON_AUDIOBOOK_SERVICE_URL=NULL
READON_PHONICS_SERVICE_URL=NULL
READON_COMPREHENSION_SERVICE_URL=NULL
READON_VISUALIZATION_SERVICE_URL=NULL

############################
# Redis / Memorystore (future)
############################
READON_REDIS_HOST=NULL
READON_REDIS_PORT=REPLACE_ME
READON_REDIS_URL=NULL

############################
# Shared third-party API keys (main app + microservices)
############################
OPENAI_API_KEY=REPLACE_ME

############################
# Microservice-specific env files (not loaded by Next automatically)
############################
# phonics:        microservices/phonics-service/.env.example
# visualization:  microservices/visualization-service/.env.example
# dashboard:      microservices/dashboard-service/.env.example
# comprehension:  microservices/comprehension-service/.env.example
# audiobook:      microservices/audiobook-service/.env.example
