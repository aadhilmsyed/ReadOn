# ReadOn - environment configuration template
#
# Notes:
# - Do NOT commit real secrets. Use `gcloud secrets` / Secret Manager when you're ready.
# - Cloud Run injects most runtime env vars from `gcloud run deploy` / `ops/gcp/deploy-*.sh`.
# - Same GCP project hosts **prod** and **test** stacks with different names (see docs/environment-separation.md).
# - Dashboard PG pools: `microservices/dashboard-service/.env`. DALL-E: `microservices/image-generation-service/.env`.
# - Comprehension LLM key: `microservices/comprehension-service/.env` (`OPENAI_API_KEY`).
# - Convention: `REPLACE_ME` = real `.env` has a value (redact here). `NULL` = real `.env` still has placeholder `REPLACE_ME`.

############################
# Which stack (local reference)
############################
READON_DEPLOY_ENV=REPLACE_ME

############################
# Shared (all environments)
############################
REGION=REPLACE_ME
CLOUDSQL_CONNECTION_NAME=REPLACE_ME

############################
# Shared Cloud SQL — TCP
############################
READON_CLOUDSQL_TCP_HOST=REPLACE_ME
READON_CLOUDSQL_TCP_PORT=REPLACE_ME
READON_CLOUDSQL_TCP_USER=REPLACE_ME
READON_CLOUDSQL_TCP_PASSWORD=REPLACE_ME

############################
# Per-service Postgres connection URLs
############################
PHONICS_DATABASE_URL=REPLACE_ME
VISUALIZATION_DATABASE_URL=REPLACE_ME
COMPREHENSION_DATABASE_URL=REPLACE_ME
DASHBOARD_DATABASE_URL=REPLACE_ME

############################
# Production-specific (READON_DEPLOY_ENV=prod)
############################
READON_STORAGE_BUCKET=REPLACE_ME
READON_DATABASE_NAME=REPLACE_ME

############################
# Common service identity (main / Next app)
############################
SERVICE_NAME=REPLACE_ME
SERVICE_VERSION=REPLACE_ME

############################
# Main Next.js app — local `npm run dev` uses port 3000; `next start` uses PORT.
############################
PORT=3000
HOST=REPLACE_ME

############################
# Logging / observability
############################
READON_LOG_LEVEL=REPLACE_ME

############################
# Cloud SQL socket / readiness
############################
READON_READY_REQUIRE_CLOUDSQL_MOUNT=REPLACE_ME

############################
# Next.js orchestrator
############################
# Local dev port map (must match `npm run dev:all` / each service’s PORT):
#   Main app 3000 | phonics 3001 | comprehension 3002 | image-gen 3003 | audiobook 3004 | dashboard 3005
# If Generate Story fails with “Dashboard service is not reachable”, set this to the dashboard URL above.
READON_DASHBOARD_SERVICE_URL=http://127.0.0.1:3005
# Optional: HTTP timeout (ms) for dashboard-service client calls from Next (1000–120000; default 15000)
READON_DASHBOARD_HTTP_TIMEOUT_MS=REPLACE_ME
READON_FEATURE_CREDIT_COST=REPLACE_ME

############################
# Auth — Next.js app (JWT in HttpOnly cookie)
############################
READON_AUTH_SECRET=REPLACE_ME
READON_AUTH_COOKIE_NAME=readon_session
READON_AUTH_SESSION_TTL=7d
READON_DEFAULT_SIGNUP_CREDITS=100

############################
# Microservice HTTP base URLs (local dev defaults; Cloud Run URLs from deploy)
############################
READON_IMAGE_GENERATION_SERVICE_URL=http://127.0.0.1:3003
READON_AUDIOBOOK_SERVICE_URL=http://127.0.0.1:3004
READON_PHONICS_SERVICE_URL=http://127.0.0.1:3001
READON_COMPREHENSION_SERVICE_URL=http://127.0.0.1:3002
# Legacy alias for image service (optional)
READON_VISUALIZATION_SERVICE_URL=NULL

############################
# Redis / Memorystore (future)
############################
READON_REDIS_HOST=NULL
READON_REDIS_PORT=REPLACE_ME
READON_REDIS_URL=NULL

############################
# Microservice `.env` files (merge with this file for local dev)
############################
# dashboard:             microservices/dashboard-service/.env.example
# image generation:      microservices/image-generation-service/.env.example
# phonics:               microservices/phonics-service/.env.example
# comprehension:         microservices/comprehension-service/.env.example
# audiobook:             microservices/audiobook-service/.env.example
