# ReadOn - environment configuration template
#
# Notes:
# - Do NOT commit real secrets. Use `gcloud secrets` / Secret Manager when you’re ready.
# - Cloud Run injects most runtime env vars from `gcloud run deploy` / `ops/gcp/deploy-*.sh`.
# - Same GCP project hosts **prod** and **test** stacks with different names (see docs/environment-separation.md).

############################
# Which stack (local reference)
############################
# prod: readon-main, readon-phonics, … and bucket readon-<project>-assets, DB readon
# test: readon-main-test, … and bucket readon-<project>-assets-test, DB readon_test
# (Deploy scripts export READON_DEPLOY_ENV from ops/gcp/vars.sh so nested bash steps stay aligned.)
READON_DEPLOY_ENV=prod

############################
# Shared (all environments)
############################
#GCP_PROJECT_ID=readon-492106
REGION=us-central1

# Artifact Registry (single repo for both environments; image tags include service name + version)
#ARTIFACT_REGISTRY_REPO=readon-artifacts
#ARTIFACT_REGISTRY_LOCATION=us-central1

# Cloud SQL instance (shared). Logical databases are split: prod uses `readon`, test uses `readon_test`.
#READON_SQL_INSTANCE=readon-sql
CLOUDSQL_CONNECTION_NAME=readon-492106:us-central1:readon-sql

############################
# Production-specific (READON_DEPLOY_ENV=prod)
############################
# Cloud Run service names
#READON_MAIN_SERVICE_NAME=readon-main
#READON_PHONICS_SERVICE_NAME=readon-phonics
#READON_COMPREHENSION_SERVICE_NAME=readon-comprehension
#READON_VISUALIZATION_SERVICE_NAME=readon-visualization
#READON_AUDIOBOOK_SERVICE_NAME=readon-audiobook

# Object storage (prod assets)
READON_STORAGE_BUCKET=readon-492106-assets

# Postgres database name on the shared instance (prod target)
READON_DATABASE_NAME=readon
# Comprehension service persistence uses DATABASE_URL directly.
# Example: postgresql://USER:PASSWORD@HOST:5432/comprehension
# URL-encode special characters in USER/PASSWORD before placing them in DATABASE_URL.
#DATABASE_URL=postgresql://readon:REPLACE_ME@localhost:5432/comprehension
#READON_DATABASE_HOST=localhost
#READON_DATABASE_PORT=5432
#READON_DATABASE_USER=readon
#READON_DATABASE_PASSWORD=REPLACE_ME
#READON_DATABASE_POOL_SIZE=5

# Runtime service accounts (emails); created by ops/gcp/provision.sh
#READON_MAIN_SA_EMAIL=readon-main-sa@readon-492106.iam.gserviceaccount.com
# … phonics / comprehension / visualization / audiobook similarly without -test suffix

############################
# Test-specific (READON_DEPLOY_ENV=test)
############################
# Service names
#READON_MAIN_SERVICE_NAME=readon-main-test
#READON_PHONICS_SERVICE_NAME=readon-phonics-test
# … etc.

#READON_STORAGE_BUCKET=readon-492106-assets-test
#READON_DATABASE_NAME=readon_test
#READON_MAIN_SA_EMAIL=readon-main-sa-test@readon-492106.iam.gserviceaccount.com

############################
# Common service identity (typical local / main app)
############################
SERVICE_NAME=readon-main
#SERVICE_VERSION=local-dev
SERVICE_VERSION=local-dev

############################
# Cloud Run runtime
############################
PORT=8080
HOST=0.0.0.0

############################
# Logging / observability
############################
READON_LOG_LEVEL=info

############################
# Cloud SQL socket / readiness (skeleton)
############################
# If true, `/ready` returns 503 until /cloudsql/<connectionName> exists.
READON_READY_REQUIRE_CLOUDSQL_MOUNT=false

############################
# Service-to-service (placeholders; deploy-stack.sh sets URLs in Cloud Run)
############################
READON_AUDIOBOOK_SERVICE_URL=REPLACE_ME
READON_PHONICS_SERVICE_URL=REPLACE_ME
# Local example: http://127.0.0.1:18080
READON_COMPREHENSION_SERVICE_URL=REPLACE_ME
READON_VISUALIZATION_SERVICE_URL=REPLACE_ME

############################
# Comprehension service placeholders
############################
# If OpenAI or READON_COMPREHENSION_LLM_ENDPOINT is empty or failing, the service uses fallback questions.
READON_COMPREHENSION_LLM_PROVIDER=openai
READON_COMPREHENSION_OPENAI_MODEL=gpt-4o-mini
#OPENAI_API_KEY=sk-proj-REPLACE_ME
READON_COMPREHENSION_LLM_ENDPOINT=REPLACE_ME
READON_COMPREHENSION_LLM_TIMEOUT_MS=30000
READON_COMPREHENSION_CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
READON_COMPREHENSION_CIRCUIT_BREAKER_RESET_MS=60000

############################
# Redis / Memorystore (future)
############################
READON_REDIS_HOST=REPLACE_ME
READON_REDIS_PORT=6379
READON_REDIS_URL=REPLACE_ME
