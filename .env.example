# ReadOn - environment configuration template
#
# Notes:
# - Do NOT commit real secrets. Use `gcloud secrets` / Secret Manager when you're ready.
# - Same GCP project hosts **prod** and **test** stacks (see docs/environment-separation.md).
# - Dashboard PG pools are configured here (Next.js). OpenAI keys live only under visualization / comprehension microservices.
# - Convention: `REPLACE_ME` = real `.env` has a value (redact in this file). `NULL` = real `.env` still has placeholder `REPLACE_ME`.

############################
# Which stack (local reference)
############################
READON_DEPLOY_ENV=REPLACE_ME

############################
# Shared (all environments)
############################
REGION=REPLACE_ME
CLOUDSQL_CONNECTION_NAME=REPLACE_ME

############################
# Shared Cloud SQL — TCP
############################
READON_CLOUDSQL_TCP_HOST=REPLACE_ME
READON_CLOUDSQL_TCP_PORT=REPLACE_ME
READON_CLOUDSQL_TCP_USER=REPLACE_ME
READON_CLOUDSQL_TCP_PASSWORD=REPLACE_ME

############################
# Per-service Postgres connection URLs
############################
PHONICS_DATABASE_URL=REPLACE_ME
VISUALIZATION_DATABASE_URL=REPLACE_ME
COMPREHENSION_DATABASE_URL=REPLACE_ME
DASHBOARD_DATABASE_URL=REPLACE_ME

############################
# Production-specific (READON_DEPLOY_ENV=prod)
############################
READON_STORAGE_BUCKET=REPLACE_ME
READON_DATABASE_NAME=REPLACE_ME

############################
# Common service identity (main / Next app)
############################
SERVICE_NAME=REPLACE_ME
SERVICE_VERSION=REPLACE_ME

############################
# Cloud Run runtime
############################
PORT=REPLACE_ME
HOST=REPLACE_ME

############################
# Logging / observability
############################
READON_LOG_LEVEL=REPLACE_ME

############################
# Cloud SQL socket / readiness
############################
READON_READY_REQUIRE_CLOUDSQL_MOUNT=REPLACE_ME

############################
# Next.js orchestrator (dashboard / features)
############################
READON_DASHBOARD_SERVICE_URL=REPLACE_ME
READON_FEATURE_CREDIT_COST=REPLACE_ME

############################
# Dashboard — embedded in Next.js (Tyler)
############################
DASHBOARD_SERVICE_NAME=REPLACE_ME
DASHBOARD_SERVICE_VERSION=REPLACE_ME
DASHBOARD_PORT=REPLACE_ME
DASHBOARD_HOST=REPLACE_ME
DASHBOARD_NODE_ENV=REPLACE_ME
DASHBOARD_CORS_ORIGIN=REPLACE_ME
PGHOST=REPLACE_ME
PGPORT=REPLACE_ME
PGUSER=REPLACE_ME
PGPASSWORD=REPLACE_ME
PHONICS_DB=REPLACE_ME
COMPREHENSION_DB=REPLACE_ME
VISUALIZATION_DB=REPLACE_ME
AUDIOBOOK_DB=REPLACE_ME
DASHBOARD_DB=REPLACE_ME

############################
# Service-to-service
############################
READON_AUDIOBOOK_SERVICE_URL=NULL
READON_PHONICS_SERVICE_URL=NULL
READON_COMPREHENSION_SERVICE_URL=NULL
READON_VISUALIZATION_SERVICE_URL=NULL

############################
# Redis / Memorystore (future)
############################
READON_REDIS_HOST=NULL
READON_REDIS_PORT=REPLACE_ME
READON_REDIS_URL=NULL

############################
# Microservice env (OpenAI keys are service-local only)
############################
# phonics:        microservices/phonics-service/.env.example
# visualization:  microservices/visualization-service/.env.example
# comprehension:  microservices/comprehension-service/.env.example
# audiobook:      microservices/audiobook-service/.env.example
