{
  "compilerOptions": {
    "target": "es5",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@views/*": ["./views/*"],
      "@orchestrators/*": ["./orchestrators/*"],
      "@shared/*": ["./shared/*"],
      "@phonics/*": ["./microservices/phonics-service/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "views/**/*.ts",
    "views/**/*.tsx",
    "shared/**/*.ts",
    "shared/**/*.tsx",
    "orchestrators/**/*.ts",
    "orchestrators/**/*.tsx",
    "microservices/phonics-service/**/*.ts",
    ".next/types/**/*.ts",
    "vitest.config.ts"
  ],
  "exclude": [
    "node_modules",
    "microservices/audiobook-service",
    "microservices/comprehension-service",
    "microservices/image-generation-service",
    "microservices/dashboard-service",
    "microservices/common"
  ]
}
